# ============================================================================
# .env.example — copiar a .env para pruebas LOCALES únicamente.
# En producción estos valores NO van en .env: van como GitHub Secrets
# (ver sección "GitHub Secrets" del README).
# ============================================================================

# --- Portal SIP GDU ---
GDU_BASE_URL=https://sip.gdu.com.uy/SIP/
GDU_PROV_ID=HI58jTqquqgVrQR

# --- Rango de fechas manual (opcional) ---
# Si se dejan vacías, el script calcula automáticamente:
# día anterior, o sábado+domingo si hoy es lunes.
TARGET_DATE_FROM=
TARGET_DATE_TO=

# --- Google Drive / Service Account ---
# Pegar acá el JSON COMPLETO de la service account, codificado en base64
# (una sola línea). Comando para generarlo:
#   base64 -w 0 sip-bot-key.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GDRIVE_FOLDER_ID=

# --- Callback hacia n8n (opcional pero recomendado) ---
N8N_CALLBACK_URL=
N8N_CALLBACK_TOKEN=

# --- Nombres de columnas del Excel (opcional) ---
# Si se conoce el orden real de columnas del Stock, listarlas separadas
# por coma. Si no, el script usa Col1, Col2, Col3...
STOCK_COLUMNS=

# --- Tuning ---
STOCK_PAGE_SIZE=2000
WS_TIMEOUT_MS=20000
