# Copiar este archivo como .env para desarrollo local
# NUNCA commitear .env con valores reales

# ID del proveedor en el portal SIP
SIP_PROV_ID=HI58jTqquqgVrQR

# ID de la carpeta de Google Drive donde se sube el Excel
# Lo encontrás en la URL: drive.google.com/drive/folders/ESTE_ES_EL_ID
GOOGLE_DRIVE_FOLDER_ID=1JroBxfSAW_jQYiWeGw-1zYI98hGm_Jq6

# JSON completo de la Service Account de Google
# Copiá todo el contenido del archivo .json que descargaste
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"sip-stock@tu-proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Directorio de salida para el Excel (en producción usa /tmp)
OUTPUT_DIR=/tmp
